# ── Modo demo (SQLite, sin SQL Server) ───────────────
# Pon DEMO_MODE=true para correr sin SQL Server.
# La base de datos se crea en demo.db y se siembra automáticamente.
DEMO_MODE=false

# ── Base de datos (SQL Server) ───────────────────────
# Solo necesario cuando DEMO_MODE=false.
DB_SERVER=localhost
DB_NAME=TransitProDB
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# ── Seguridad (JWT) ──────────────────────────────────
# Genera una clave aleatoria de mínimo 32 caracteres, p.ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-de-32-caracteres

# ── CORS ─────────────────────────────────────────────
# Orígenes permitidos separados por coma. En producción pon tu dominio.
# CORS_ORIGINS=https://tu-dominio.com,https://otro.com
CORS_ORIGINS=*

# ── Bot de Telegram ──────────────────────────────────
# Token que entrega @BotFather al crear el bot.
BOT_TOKEN=123456789:tu-token-de-telegram-aqui
