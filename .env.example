# ── Base de datos (SQL Server) ───────────────────────
# Copia este archivo a ".env" y completa con tus credenciales reales.
DB_SERVER=localhost
DB_NAME=TransitProDB
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# ── Seguridad (JWT) ──────────────────────────────────
# Genera una clave aleatoria de mínimo 32 caracteres, p.ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-de-32-caracteres

# ── Bot de Telegram ──────────────────────────────────
# Token que entrega @BotFather al crear el bot.
BOT_TOKEN=123456789:tu-token-de-telegram-aqui
